---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";

const title = "Markus Baumann GitHub";
const description =
  "GitHub profile overview for Markus Baumann (@eybmits), a LMU Munich / QAR-Lab researcher working on Quantum Reservoir Computing, Quantum Machine Learning, time-series forecasting, and reproducible research software.";
const siteUrl = SITE.website.replace(/\/$/, "");
const pageUrl = `${siteUrl}/markus-baumann-github`;
const personId = `${siteUrl}/#person`;

const profilePageData = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${pageUrl}#profilepage`,
  name: title,
  description,
  url: pageUrl,
  mainEntity: {
    "@type": "Person",
    "@id": personId,
    name: SITE.author,
    alternateName: "eybmits",
    url: siteUrl,
    sameAs: [
      "https://github.com/eybmits",
      "https://scholar.google.com/citations?hl=en&user=gjjgrw0AAAAJ",
      "https://www.ifi.lmu.de/mvs/de/team/kontaktseite/markus-baumann-eb504667.html",
      "https://qarlab.de/en/",
    ],
    jobTitle: "Researcher",
    affiliation: {
      "@type": "Organization",
      name: "LMU Munich / QAR-Lab",
      url: "https://qarlab.de/en/",
    },
    knowsAbout: [
      "Quantum Reservoir Computing",
      "Quantum Machine Learning",
      "time-series forecasting",
      "reproducible research software",
    ],
  },
};
---

<Layout title={title} description={description} canonicalURL={pageUrl}>
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <section class="prose mt-8 max-w-3xl">
      <h1>Markus Baumann GitHub</h1>
      <p>
        This page connects the public GitHub profile of <strong>Markus Baumann</strong>
        with the same research identity used on this website, Google Scholar, LMU Munich,
        and QAR-Lab.
      </p>

      <h2>Primary GitHub Profile</h2>
      <p>
        The current GitHub profile is
        <a href="https://github.com/eybmits" rel="me">Markus Baumann (@eybmits)</a>.
        It is used for public research code, reproducibility packages, project notes,
        and software connected to Quantum Reservoir Computing, Quantum Machine Learning,
        time-series forecasting, and reproducible computational research.
      </p>

      <h2>Research Repositories</h2>
      <ul>
        <li>
          <a href="https://github.com/eybmits/qrc-operating-band">qrc-operating-band</a>:
          reproducibility package for Quantum Reservoir Computing operating-band experiments.
        </li>
        <li>
          <a href="https://github.com/eybmits/qc_symmetry">qc_symmetry</a>:
          public reproducibility package for symmetry-focused quantum-computing experiments.
        </li>
        <li>
          <a href="https://github.com/eybmits/iqp_generative">iqp_generative</a>:
          artifacts and figure pipelines for parity-structured quantum generative modeling.
        </li>
        <li>
          <a href="https://github.com/eybmits/parameterized-hamiltonians-id"
            >parameterized-hamiltonians-id</a
          >:
          implicit-differentiation experiments for bilevel Max-Cut optimization.
        </li>
        <li>
          <a href="https://github.com/eybmits/QRC-statistically">QRC-statistically</a>:
          archival research project on statistically learnable Quantum Reservoir Computing.
        </li>
      </ul>

      <h2>Canonical Identity Links</h2>
      <ul>
        <li><a href="/" rel="me">Personal website for Markus Baumann</a></li>
        <li><a href="https://github.com/eybmits" rel="me">Markus Baumann on GitHub</a></li>
        <li>
          <a href="https://scholar.google.com/citations?hl=en&user=gjjgrw0AAAAJ" rel="me"
            >Markus Baumann on Google Scholar</a
          >
        </li>
        <li>
          <a
            href="https://www.ifi.lmu.de/mvs/de/team/kontaktseite/markus-baumann-eb504667.html"
            rel="me"
            >Markus Baumann at LMU Munich</a
          >
        </li>
        <li><a href="https://qarlab.de/en/">QAR-Lab</a></li>
      </ul>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(profilePageData)} />
</Layout>
