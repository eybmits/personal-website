---
import { getCollection } from "astro:content";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Hr from "@/components/Hr.astro";
import LinkButton from "@/components/LinkButton.astro";
import Socials from "@/components/Socials.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE, SOCIALS } from "@/config";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const pinnedTitle = "Things I Believe In";
const pinnedPost = sortedPosts.find(({ data }) => data.title === pinnedTitle);
const featuredPosts = sortedPosts.filter(
  ({ data }) => data.featured && data.title !== pinnedTitle
);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout description={SITE.desc}>
  <StructuredData type="WebSite" data={{}} />
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-6 pb-4">
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a href="/about" class="block mx-auto sm:mx-0 group">
          <img
            src="/avatar.svg"
            alt={SITE.author}
            class="w-40 h-40 rounded-full object-cover flex-shrink-0 transition-all duration-300 group-hover:scale-105 group-hover:shadow-xl"
          />
        </a>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center gap-2 justify-center sm:justify-start">
            <h1 class="my-2 inline-block text-2xl font-bold sm:my-4 sm:text-3xl">
              Hi, I'm {SITE.title}.
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              class="inline-block"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss width={20} height={20} class="scale-125 stroke-accent stroke-3" />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>
          <p>{SITE.desc}</p>
          {
            SOCIALS.filter((social) => social.active).length > 0 && (
              <div class="mt-4 flex flex-row items-center justify-center sm:justify-start">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <Hr />

    {
      pinnedPost && (
        <>
          <section id="pinned-post" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              <Card variant="h3" {...pinnedPost} showImage={false} />
            </ul>
          </section>
          <Hr />
        </>
      )
    }

    <section id="public-documentation-hub" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">📚 Public Documentation Hub</h2>
      <p class="mt-2 opacity-80">
        Public project documentation, implementation notes, and reproducible guides.
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <article class="rounded-lg border border-border p-4">
          <h3 class="text-lg font-medium">
            <a href="https://github.com/eybmits/website" target="_blank" rel="noopener noreferrer">
              QRC Documentation Website
            </a>
          </h3>
          <p class="mt-2 opacity-80">
            Interactive QRC documentation with long-form explanations and review material.
          </p>
        </article>
        <article class="rounded-lg border border-border p-4">
          <h3 class="text-lg font-medium">
            <a href="https://github.com/eybmits/quards-phd/tree/main/docs" target="_blank" rel="noopener noreferrer">
              QuaRDS Project Docs
            </a>
          </h3>
          <p class="mt-2 opacity-80">
            Architecture notes, experiment cards, and reproducibility documentation.
          </p>
        </article>
      </div>
    </section>

    <Hr />

    <section id="open-research" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">🧪 Open Research</h2>
      <p class="mt-2 opacity-80">
        Active research tracks shared publicly, including in-progress methods and results.
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <article class="rounded-lg border border-border p-4">
          <h3 class="text-lg font-medium">
            <a
              href="https://github.com/eybmits/parameterized-hamiltonians-id"
              target="_blank"
              rel="noopener noreferrer"
            >
              ParamHam
            </a>
          </h3>
          <p class="mt-2 opacity-80">
            Parameterized Hamiltonian research with open code and empirical studies.
          </p>
        </article>
        <article class="rounded-lg border border-border p-4">
          <h3 class="text-lg font-medium">
            <a href="https://github.com/eybmits/qrc_budget" target="_blank" rel="noopener noreferrer">
              QRC Budget
            </a>
          </h3>
          <p class="mt-2 opacity-80">
            Budget-aware quantum reservoir experiments and ablation-driven analysis.
          </p>
        </article>
      </div>
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map((data) => (
                <Card variant="h3" {...data} showImage={false} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} showImage={false} />,
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = document.querySelector("#main-content")?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
