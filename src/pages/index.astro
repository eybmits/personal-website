---
import { getCollection } from "astro:content";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconLab from "@/assets/icons/IconLab.svg";
import IconMail from "@/assets/icons/IconMail.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import IconScholar from "@/assets/icons/IconScholar.svg";
import IconUniversity from "@/assets/icons/IconUniversity.svg";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Hr from "@/components/Hr.astro";
import LinkButton from "@/components/LinkButton.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getPath } from "@/utils/getPath";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const beliefsPost = sortedPosts.find(({ data }) => data.title === "Principles");
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const heroIconLinks = [
  {
    href: "/about#open-research",
    label: "Research artifacts",
    title: "Research artifacts",
    Icon: IconArchive,
  },
  {
    href: "https://github.com/eybmits",
    label: "GitHub",
    title: "Markus Baumann on GitHub",
    Icon: IconGitHub,
    rel: "me",
  },
  {
    href: "https://scholar.google.com/citations?hl=en&user=gjjgrw0AAAAJ",
    label: "Google Scholar",
    title: "Google Scholar",
    Icon: IconScholar,
    rel: "me",
  },
  {
    href: "https://www.ifi.lmu.de/mvs/de/team/kontaktseite/markus-baumann-eb504667.html",
    label: "LMU profile",
    title: "LMU profile",
    Icon: IconUniversity,
    rel: "me",
  },
  {
    href: "https://qarlab.de/en/",
    label: "QAR-Lab",
    title: "QAR-Lab",
    Icon: IconLab,
  },
  {
    href: `mailto:${SITE.email}`,
    label: "Email",
    title: "Email Markus Baumann",
    Icon: IconMail,
  },
];
---

<Layout
  title="Markus Baumann | Quantum Reservoir Computing & Machine Learning"
  description={SITE.desc}
>
  <StructuredData type="WebSite" data={{}} />
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-6 pb-4">
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a href="/about" class="block mx-auto sm:mx-0 group">
          <img
            src="/avatar.png"
            alt={SITE.author}
            class="w-40 h-40 rounded-full object-cover flex-shrink-0 transition-all duration-300 group-hover:scale-105 group-hover:shadow-xl"
          />
        </a>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center gap-2 justify-center sm:justify-start">
            <h1 class="my-2 inline-block text-2xl font-bold sm:my-4 sm:text-3xl">
              Hi, I'm {SITE.title}.
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              class="inline-block"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss width={20} height={20} class="scale-125 stroke-accent stroke-3" />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>
          <p>
            {SITE.desc}
            {
              beliefsPost && (
                <>
                  {" "}
                  <a
                    href={getPath(beliefsPost.id, beliefsPost.filePath)}
                    class="text-accent decoration-dashed underline underline-offset-4 hover:no-underline"
                  >
                    Principles I believe in.
                  </a>
                </>
              )
            }
          </p>
          <div class="mt-5 flex items-center justify-center gap-3 sm:justify-start">
            {
              heroIconLinks.map(({ href, label, title, Icon, rel }) => (
                <a
                  href={href}
                  rel={rel}
                  aria-label={label}
                  title={title}
                  class="inline-flex size-10 items-center justify-center text-foreground/85 transition hover:-translate-y-0.5 hover:text-accent"
                >
                  <Icon class="size-7 fill-transparent stroke-current stroke-2" />
                  <span class="sr-only">{label}</span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map((data) => (
                <Card variant="h3" {...data} showImage={false} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} showImage={false} />,
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = document.querySelector("#main-content")?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
